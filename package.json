{
  "name": "cluely-copy",
  "version": "1.0.0",
  "description": "AI overlay desktop app",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"vite --config vite.overlay.config.ts\" \"wait-on http://localhost:5173 http://localhost:5174 && electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build && vite build --config vite.overlay.config.ts && electron-builder",
    "build:main": "tsc -p tsconfig.main.json",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^1.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "electron-store": "^8.1.0",
    "mammoth": "^1.6.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^6.21.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^4.4.0"
  }
}
